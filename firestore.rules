rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: soil_tests
    // Document ID: auto-generated
    // Fields:
    //   - temperature: number (required)
    //   - humidity: number (required)
    //   - conductivity: number (required)
    //   - ph: number (required)
    //   - nitrogen: number (required)
    //   - phosphorus: number (required)
    //   - potassium: number (required)
    //   - fertility: number (required)
    //   - timestamp: number (required) - Unix timestamp
    //   - uid: string (required) - Owner's UID
    //   - farmerId: string (optional) - ID of the farmer profile
    //   - farmerName: string (optional) - Name of the farmer
    //   - location: map (optional)
    //     - latitude: number (required)
    //     - longitude: number (required)
    //
    // Collection: farmers
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - phone: string (optional)
    //   - email: string (optional)
    //   - farmName: string (required)
    //   - farmLocation: string (optional)
    //   - uid: string (required) - Agronomist's UID
    //   - createdAt: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "intelligentsoil.ai@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidSoilTest(data) {
      return hasRequiredFields(['temperature', 'humidity', 'conductivity', 'ph', 'nitrogen', 'phosphorus', 'potassium', 'fertility', 'timestamp', 'uid']) &&
             data.temperature is number &&
             data.humidity is number &&
             data.conductivity is number &&
             data.ph is number &&
             data.nitrogen is number &&
             data.phosphorus is number &&
             data.potassium is number &&
             data.fertility is number &&
             data.timestamp is number &&
             data.uid is string &&
             (!('farmerId' in data) || (data.farmerId is string && data.farmerId.size() < 50)) &&
             (!('farmerName' in data) || (data.farmerName is string && data.farmerName.size() < 100)) &&
             (!('location' in data) || (data.location is map && data.location.latitude is number && data.location.longitude is number));
    }

    function isValidFarmer(data) {
      return hasRequiredFields(['name', 'farmName', 'uid', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.farmName is string && data.farmName.size() > 0 && data.farmName.size() < 100 &&
             data.uid is string &&
             data.createdAt is number &&
             (!('phone' in data) || (data.phone is string && data.phone.size() < 20)) &&
             (!('email' in data) || (data.email is string && data.email.size() < 100)) &&
             (!('farmLocation' in data) || (data.farmLocation is string && data.farmLocation.size() < 200));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /soil_tests/{testId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidSoilTest(request.resource.data) && uidUnchanged();
      allow update: if false; // Soil tests are immutable once saved
      allow delete: if isDocOwner() || isAdmin();
    }

    match /farmers/{farmerId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidFarmer(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidFarmer(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && request.resource.data.role == 'user';
      allow update: if isAdmin(); // Only admins can change roles
      allow delete: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
